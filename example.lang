// --- Управление потоком ------------------------------------------------

// if как выражение
let label = if score >= 90 { "A" } else if score >= 80 { "B" } else { "C" }

// for-in (единственный for)
for x in nums { print(x) }
for i in 0..10 { print(i) }
for (i, x) in nums.enumerate() { print("${i}: ${x}") }
for (key, val) in map { print("${key}=${val}") }

// while / loop
while counter < 10 { counter += 1 }
loop {
    if done() { break }
}

// break / continue с метками
'outer: for i in 0..10 {
    for j in 0..10 {
        if i * j > 50 { break 'outer }
    }
}


