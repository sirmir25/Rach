// --- Обработка ошибок: Result + Option ---------------------------------

enum Result<T, E> { Ok(T), Err(E) }
enum Option<T>    { Some(T), None }

fn parse(s: string) -> Result<int, string> {
    if s.is_empty() { return Err("empty") }
    Ok(s.to_int())
}

// оператор ? — пробрасывает ошибку наверх
fn double_parse(s: string) -> Result<int, string> {
    let n = parse(s)?
    Ok(n * 2)
}

// ?. для опциональных значений
let len = user?.profile?.name?.len()


// --- Defer (cleanup) ---------------------------------------------------

fn read_file(path: string) -> Result<string, IoError> {
    let f = File.open(path)?
    defer f.close()              // выполнится при выходе из функции
    f.read_all()
}


// --- Перегрузка операторов ---------------------------------------------

struct Vec2 { x: float, y: float }

impl Vec2 {
    op + (self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }
    op == (self, other: Vec2) -> bool {
        self.x == other.x and self.y == other.y
    }
    op [] (self, i: int) -> float {
        if i == 0 { self.x } else { self.y }
    }
}


// --- Concurrency (async/await) -----------------------------------------

async fn fetch(url: string) -> Result<string, NetError> {
    let resp = http.get(url).await?
    Ok(resp.body)
}

async fn main() {
    let (a, b) = await.all(
        fetch("https://a.com"),
        fetch("https://b.com"),
    )
}


