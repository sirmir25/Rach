// --- Структуры ---------------------------------------------------------

struct Person {
    name: string
    age: int
    email: string?           // опциональное поле (Option<string>)
}

// конструктор / литерал
let ivan = Person { name: "Ivan", age: 25, email: none }

// методы через impl
impl Person {
    fn greet(self) -> string {
        return "Hi, I am ${self.name}"
    }

    fn birthday(mut self) {
        self.age += 1
    }

    // ассоциированная функция (без self)
    fn anonymous() -> Person {
        return Person { name: "?", age: 0, email: none }
    }
}


// --- Enum (sum types) --------------------------------------------------

enum Shape {
    Circle(radius: float)
    Rectangle(w: float, h: float)
    Triangle { a: float, b: float, c: float }
    Empty
}

enum Color { Red, Green, Blue }     // простые варианты


// --- Type aliases ------------------------------------------------------

type Id = int
type Handler = fn(Request) -> Response
type Pair<T> = (T, T)


// --- Функции -----------------------------------------------------------

fn add(a: int, b: int) -> int {
    return a + b
}

// возврат по последнему выражению (без return)
fn square(x: int) -> int { x * x }

// несколько возвращаемых значений (кортеж)
fn divmod(a: int, b: int) -> (int, int) {
    (a / b, a % b)
}

// дефолтные параметры
fn greet(name: string, greeting: string = "Hello") -> string {
    "${greeting}, ${name}"
}

// именованные аргументы при вызове
let msg = greet(name: "Ivan", greeting: "Привет")

// vararg
fn sum(nums: ...int) -> int {
    var total = 0
    for n in nums { total += n }
    total
}


// --- Дженерики ---------------------------------------------------------

fn first<T>(xs: [T]) -> T? {
    if xs.len() == 0 { return none }
    some(xs[0])
}

struct Stack<T> {
    items: [T]
}

impl<T> Stack<T> {
    fn push(mut self, x: T) { self.items.push(x) }
    fn pop(mut self)  -> T? { self.items.pop() }
}

// ограничения (trait bounds)
fn max<T: Ord>(a: T, b: T) -> T {
    if a > b { a } else { b }
}


// --- Trait / интерфейсы ------------------------------------------------

trait Drawable {
    fn draw(self)
    fn area(self) -> float
    fn describe(self) -> string {       // дефолтная реализация
        "Shape with area ${self.area()}"
    }
}

impl Drawable for Shape {
    fn draw(self) { /* ... */ }
    fn area(self) -> float {
        match self {
            Circle(r)        => PI * r * r
            Rectangle(w, h)  => w * h
            Triangle { a, b, c } => {
                let s = (a + b + c) / 2.0
                sqrt(s * (s-a) * (s-b) * (s-c))
            }
            Empty            => 0.0
        }
    }
}


// --- Lambdas / closures ------------------------------------------------

let double = (x: int) => x * 2
let inline = (x) => x + 1                // тип из контекста
let block  = (x: int) => { let y = x + 1; y * 2 }

// trailing-lambda синтаксис (приятно для DSL)
let evens = nums.filter { x => x % 2 == 0 }
let sum   = nums.reduce(0) { acc, x => acc + x }


// --- Pipe оператор -----------------------------------------------------

let result = data
