# No boilerplate. Top-level statements run in order.
# Short aliases mirror Unix utilities: os, read, write, exists, del, run, sh, rm.

print("hello, rach")

os()
write("/tmp/r.txt", "data")
read("/tmp/r.txt")
exists("/tmp/r.txt")

# Variables without the `set` keyword
nums = [3, 1, 4, 1, 5]
for n in nums:
    sh("echo iter")

# Native (C/C++) helpers
native_sort_ints("3,1,4,1,5,9,2,6")
ascii_banner("OK")

del("/tmp/r.txt")
